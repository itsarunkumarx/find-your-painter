{
  "appId": "com.findyourpainter.app",
  "appName": "Find Your Painter",
  "webDir": "dist",
  "server": {
    "url": "https://find-your-painter.vercel.app",
    "cleartext": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#020617",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#020617"
    }
  },
  "loggingBehavior": "none"
}
